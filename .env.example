# Main LLM provider used when --model-provider=minmax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=minimax-m2.7-highspeed

# Alternative OpenRouter/Claude-compatible provider used when --model-provider=claude
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=

# Optional web/image/search/visual-QA settings
TAVILY_API_KEY=
SEARCH_PROVIDER=auto
SEARXNG_BASE_URL=
UNSPLASH_ACCESS_KEY=
IMAGE_PROVIDER=minimax
MINIMAX_IMAGE_MODEL=image-01
ARK_API_KEY=
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_VL_MODEL=qwen-vl-max

# Runtime tuning
MAX_PPT_SLIDES=60
DIRECTIONAI_PPT_RENDER_CONCURRENCY=2
PPT_OUTPUT_DIR=./outputs

