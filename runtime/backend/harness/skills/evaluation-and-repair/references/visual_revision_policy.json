        "content_score": 3.0,
        "design_score": 2.8
      }
    },
    {
      "name": "structure_failure",
      "patterns": ["层级乱", "阅读路径", "重心散", "结构混乱", "节点未对齐", "流程图松散", "未对齐", "一侧过空", "图文失衡", "视觉重心偏移"],
      "force_revision": false,
      "score_caps": {
        "layout_score": 3.0
      }
    }
  ],
  "fallback_suggestion_for_severe_issue": "优先修复主视觉失效、越界、图文比例失衡或结构未对齐问题，再调整风格细节。"
