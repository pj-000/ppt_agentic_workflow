      "force_revision": true,
      "score_caps": {
        "content_score": 2.8,
        "design_score": 2.8
      }
    },
    {
      "name": "visual_balance_failure",
      "patterns": ["空白", "空框", "大面积留白", "大片留白", "版面利用率低", "主视觉过大", "图文比例失衡", "信息区过空", "卡片过大但信息过少"],
      "force_revision": false,
      "score_caps": {
